# ── Required ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Reddit (optional — RSS works without it) ──────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=BreakingWeirdV2/2.0

# ── NewsAPI (optional) ────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key

# ── Pexels stock footage (optional) ──────────────────────────────────────
PEXELS_API_KEY=your_pexels_key

# ── YouTube ───────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS=client_secrets.json
YOUTUBE_TOKEN_PATH=token.pickle
YOUTUBE_CHANNEL_ID=your_channel_id

# ── Social platforms (optional) ───────────────────────────────────────────
TIKTOK_SESSION_ID=your_tiktok_session_cookie
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ── Image generation ──────────────────────────────────────────────────────
IMAGE_TIER=pollinations       # pollinations | comfyui
USE_COMFYUI=false
COMFYUI_URL=http://localhost:8188

# ── Queue ─────────────────────────────────────────────────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0

# ── Pipeline tuning ───────────────────────────────────────────────────────
STORIES_PER_RUN=1
TOP_STORIES_POOL=30
MIN_VIRAL_SCORE=6.0
SCENES_PER_VIDEO=7
NARRATOR_STYLE=deadpan        # deadpan|horror_documentary|sarcastic|investigative|hyper_tiktok

# ── Paths ─────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
DB_PATH=data/breaking_weird.db
